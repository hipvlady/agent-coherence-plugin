{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COHERENCE_PORT}/hooks/pre-read",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COHERENCE_PORT}/hooks/pre-edit",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COHERENCE_PORT}/hooks/post-edit",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/ensure-coordinator"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://127.0.0.1:${COHERENCE_PORT}/hooks/session-stop",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
