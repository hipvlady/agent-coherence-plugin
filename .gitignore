# OS / editor noise
.DS_Store
*.swp
.vscode/
.idea/

# Coordinator runtime state — NEVER commit (KTD-13 defense-in-depth)
.coherence/

# Test / harness artifacts — NEVER commit (Unit 9 transcript scrubbing)
*.stream.jsonl
*.transcript.json
/tmp-test/

# Node toolchain (v0.1.1 Node MESI-subset coordinator lives at plugin root per KTD-C)
# package-lock.json IS committed for deterministic install at SessionStart hook time.
# node_modules/ is NOT committed — installed lazily into ${CLAUDE_PLUGIN_DATA} per KTD-C.
node_modules/
*.log
npm-debug.log*
dist/
build/
*.tsbuildinfo

# Python toolchain (for local dev / scripts only — coordinator is installed via pip from the library)
__pycache__/
*.py[cod]
.venv/
venv/

# Claude Code session state
.claude/

# Local-only docs (per agent-coherence convention)
docs/local/
*.local.md

# Obsidian artifacts (vault metadata, not project files)
.obsidian/
**/.obsidian/

# Internal validation surfaces — kept local, not part of the public plugin source.
# Probes are commit-time validation runs against specific Claude Code versions;
# known-issues are tracked as GitHub issues (https://github.com/hipvlady/agent-coherence-plugin/issues)
# with the original local files retained for design-pass reference.
docs/probes/
docs/known-issues/

